{
  "name": "apostil",
  "version": "0.1.2",
  "description": "Pin-and-comment feedback overlay for design prototypes and web apps",
  "license": "MIT",
  "author": "Batzorigco",
  "repository": {
    "type": "git",
    "url": "https://github.com/batzorigco/apostil.git"
  },
  "keywords": [
    "comments",
    "feedback",
    "annotation",
    "prototype",
    "design",
    "overlay",
    "review",
    "collaboration"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters/localStorage": {
      "types": "./dist/adapters/localStorage.d.ts",
      "import": "./dist/adapters/localStorage.js"
    },
    "./adapters/rest": {
      "types": "./dist/adapters/rest.d.ts",
      "import": "./dist/adapters/rest.js"
    },
    "./adapters/nextjs": {
      "types": "./dist/adapters/nextjs.d.ts",
      "import": "./dist/adapters/nextjs.js"
    }
  },
  "bin": {
    "apostil": "./bin/apostil.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jsdom": "^29.0.1",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
